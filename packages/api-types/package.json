{
  "name": "@towk/api-types",
  "private": true,
  "version": "0.4.0-beta.4",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./admin/*": {
      "types": "./dist/chatto/admin/*.d.ts",
      "import": "./dist/chatto/admin/*.js"
    },
    "./api/*": {
      "types": "./dist/chatto/api/*.d.ts",
      "import": "./dist/chatto/api/*.js"
    },
    "./chatto/*": {
      "types": "./dist/chatto/*.d.ts",
      "import": "./dist/chatto/*.js"
    },
    "./realtime/*": {
      "types": "./dist/chatto/realtime/*.d.ts",
      "import": "./dist/chatto/realtime/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist src/chatto src/buf"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "typescript": "^6.0.3"
  }
}
