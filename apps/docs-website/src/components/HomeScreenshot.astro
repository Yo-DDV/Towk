---
import { Image } from "astro:assets";
import towkDark from "../assets/towk_dark.png";
import towkLight from "../assets/towk_light.png";
---

<figure class="towk-home-screenshot">
  <Image
    class="towk-home-screenshot__image towk-home-screenshot__image--light"
    src={towkLight}
    alt="Towk overview showing server navigation, available rooms, and the current account."
    widths={[720, 1080, 1440, 1920]}
    sizes="(min-width: 72rem) 72rem, calc(100vw - 2rem)"
  />
  <Image
    class="towk-home-screenshot__image towk-home-screenshot__image--dark"
    src={towkDark}
    alt="Towk overview in dark mode showing server navigation, available rooms, and the current account."
    widths={[720, 1080, 1440, 1920]}
    sizes="(min-width: 72rem) 72rem, calc(100vw - 2rem)"
  />
</figure>

<style>
  .towk-home-screenshot {
    max-width: 72rem;
    margin: 0 auto;
  }

  .towk-home-screenshot__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
  }

  :global(:root[data-theme="dark"]) .towk-home-screenshot__image--light,
  :global(:root:not([data-theme="dark"])) .towk-home-screenshot__image--dark {
    display: none;
  }

  @media (min-width: 64rem) {
    .towk-home-screenshot {
      margin-top: -6rem;
    }
  }
</style>
