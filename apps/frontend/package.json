{
  "name": "towk-frontend",
  "private": true,
  "version": "0.6.1",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check:i18n": "node --test scripts/i18n-facade-parser.test.mjs && node scripts/check-i18n-catalogs.mjs",
    "paraglide": "pnpm run check:i18n && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations --output-structure locale-modules --silent && node scripts/generate-i18n-facade.mjs",
    "prepare": "svelte-kit sync || echo ''",
    "check": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test:audio:browser": "vitest --run --project client src/lib/audio/backgroundNoiseSuppression.svelte.spec.ts",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:native-clipboard": "playwright test --config playwright.native-clipboard.config.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "pnpm --filter @towk/api-types build && storybook build"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/ibm-plex-sans": "^5.3.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@iconify/json": "^2.2.503",
    "@iconify/tailwind4": "^1.2.3",
    "@inlang/paraglide-js": "^2.22.0",
    "@inlang/plugin-m-function-matcher": "^2.2.9",
    "@inlang/plugin-message-format": "^4.4.0",
    "@parcel/watcher": "^2.6.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/sveltekit": "^10.5.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.3",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-code-block-lowlight": "3.28.0",
    "@tiptap/extension-link": "3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/markdown": "3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.19",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.5.2",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^17.7.0",
    "highlight.js": "^11.11.1",
    "lowlight": "3.3.0",
    "markdown-it": "^14.3.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "sharp": "^0.35.3",
    "storybook": "^10.5.2",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte-dnd-action": "^0.9.74",
    "svelte2tsx": "^0.7.58",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "virtua": "^0.49.3",
    "vite": "^7.3.6",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^2.1.1",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-web": "^2.1.2",
    "@sapphi-red/web-noise-suppressor": "0.3.5",
    "@towk/api-types": "workspace:*",
    "gemoji": "^8.1.0",
    "heic2any": "^0.0.4",
    "js-sha256": "^0.12.0",
    "linkify-it": "^6.0.0",
    "livekit-client": "^2.20.1",
    "tlds": "^1.261.0",
    "vidstack": "^1.15.6"
  }
}
